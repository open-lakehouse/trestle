# MLflow tracking server
#
# This fragment is a `RenderSpec::Template`, so it is rendered with MiniJinja against the
# plan-time `RenderCtx`. It reads three kinds of value:
#
#   * MiniJinja `env.X` refs — plan-time, render-only values the planner injected that never
#     reach `.env`, e.g. `BASE_PATH` (the gateway base path chosen for MLflow's prefixable
#     UI). These must be MiniJinja refs, not compose `${VAR}`, since compose could not
#     resolve a var absent from `.env`.
#   * MiniJinja typed objects — `dependencies` (the `depends_on` gates, each chosen
#     provider's service + condition) and `connections.object_store.0` (the object-store
#     connection the fragment branches on by credential flavour).
#   * `${X}` — run-time compose substitutions resolved from `.env` (the bound connection
#     coordinates: `MLFLOW_BACKEND_STORE_URI`, `MLFLOW_ARTIFACTS_DESTINATION`,
#     `MLFLOW_S3_ENDPOINT_URL`).
{%- set obj = connections.object_store.0 %}
services:
  mlflow:
    image: ghcr.io/mlflow/mlflow:v3.10.1-full
    restart: unless-stopped
    profiles: [svc, full]
    depends_on:
{%- for dep in dependencies %}
      {{ dep.service }}:
        condition: {{ dep.condition }}
{%- endfor %}
    command:
      - "mlflow"
      - "server"
      - "--backend-store-uri"
      - "${MLFLOW_BACKEND_STORE_URI}"
      - "--artifacts-destination"
      - "${MLFLOW_ARTIFACTS_DESTINATION}"
      - "--serve-artifacts"
      - "--host"
      - "0.0.0.0"
      - "--port"
      - "5000"
      - "--static-prefix"
      - "{{ env.BASE_PATH }}"
    environment:
{%- if obj.credential.flavour == "s3" %}
      MLFLOW_S3_ENDPOINT_URL: ${MLFLOW_S3_ENDPOINT_URL}
      AWS_ACCESS_KEY_ID: {{ obj.credential.access_key_id }}
      AWS_SECRET_ACCESS_KEY: {{ obj.credential.secret_access_key }}
      AWS_DEFAULT_REGION: {{ obj.credential.region }}
{%- else %}
      AZURE_STORAGE_CONNECTION_STRING: {{ obj.credential.connection_string }}
{%- endif %}
    expose:
      - "5000"
    healthcheck:
      test:
        - "CMD-SHELL"
        - "python3 -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:5000{{ env.BASE_PATH }}/health')\""
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s
