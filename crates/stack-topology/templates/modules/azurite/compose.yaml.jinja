# Azurite (Azure Blob emulator)
services:
  azurite:
    image: mcr.microsoft.com/azure-storage/azurite:3.35.0
    restart: unless-stopped
    command:
      ["azurite-blob", "--blobHost", "0.0.0.0", "--blobPort", "10000", "--skipApiVersionCheck"]
    expose:
      - "10000"
    volumes:
      - {{ env.DATA_ROOT }}/azurite:/data
    healthcheck:
      test:
        - "CMD-SHELL"
        - "nc -z 127.0.0.1 10000 || exit 1"
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 3s
{%- if objects %}
{%- set obj = connections.object_store.0 %}

  azurite-init:
    image: mcr.microsoft.com/azure-cli:2.87.0
    restart: "no"
    depends_on:
      azurite:
        condition: service_healthy
    environment:
      AZURE_STORAGE_CONNECTION_STRING: {{ obj.credential.connection_string }}
    entrypoint:
      - "sh"
      - "-c"
      - |
        echo "Creating Azurite containers...";
{%- for name in objects %}
        az storage container create --name {{ name }} 2>&1 || true;
{%- endfor %}
        echo "Containers ready.";
{%- endif %}
