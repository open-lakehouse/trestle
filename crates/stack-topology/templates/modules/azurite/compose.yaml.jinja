# Azurite (Azure Blob emulator) — object-store provider, an alternative to SeaweedFS.
#
# This fragment is a `RenderSpec::Template`, rendered whole against the typed `RenderCtx` —
# no compose `${VAR}` substitution layered on top. As a provider, Azurite renders against its
# own role:
#
#   * `connections.object_store.0` — its own resolved connection; the fragment reads the
#     credential's `connection_string` directly.
#   * `objects` — the container names the stack provisions on it; the one-shot init iterates
#     them to create each, instead of the planner splicing pre-formatted shell lines.
#
# The blob port is the emulator's fixed 10000, written directly. Durable blob state is
# persisted under the stack's data root (`env.DATA_ROOT`, default ./.data), resolved at plan
# time — relocating the stack's data is a single `PlanCtx.data_root` knob, not a per-fragment edit.
{%- set obj = connections.object_store.0 %}
services:
  azurite:
    image: mcr.microsoft.com/azure-storage/azurite:3.35.0
    restart: unless-stopped
    command:
      ["azurite-blob", "--blobHost", "0.0.0.0", "--blobPort", "10000", "--skipApiVersionCheck"]
    ports:
      - "10000:10000"
    volumes:
      - {{ env.DATA_ROOT }}/azurite:/data
    healthcheck:
      test:
        - "CMD-SHELL"
        - "nc -z 127.0.0.1 10000 || exit 1"
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 3s

  azurite-init:
    image: mcr.microsoft.com/azure-cli:2.87.0
    restart: "no"
    profiles: [svc, full]
    depends_on:
      azurite:
        condition: service_healthy
    environment:
      AZURE_STORAGE_CONNECTION_STRING: {{ obj.credential.connection_string }}
    entrypoint:
      - "sh"
      - "-c"
      - |
        echo "Creating Azurite containers...";
{%- for name in objects %}
        az storage container create --name {{ name }} 2>&1 || true;
{%- endfor %}
        echo "Containers ready.";
