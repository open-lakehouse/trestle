# Headwaters lineage service — contributed by the `headwaters` module.
{%- set db = connections.relational_db.0 %}
services:
  headwaters:
    image: ghcr.io/open-lakehouse/headwaters:0.0.5
    restart: unless-stopped
    depends_on:
{%- for dep in dependencies %}
      {{ dep.service }}:
        condition: {{ dep.condition }}
{%- endfor %}
    environment:
      # DSN read straight from the typed relational_db connection (no `.env` round-trip);
      # `{name}` resolves to the demanded database name (`lineage`). Headwaters runs its
      # own sqlx migrations against this at startup.
      DATABASE_URL: "{{ db.url }}"
      HEADWATERS__PORT: "8091"
      # Planner-assigned base path for the shared-listener UI prefix (the `--static-prefix`
      # handshake). Envoy fronts `{{ env.BASE_PATH }}` and forwards it upstream unchanged,
      # so the service must serve its whole surface under the same prefix.
      HEADWATERS__UI__BASE_PATH: "{{ env.BASE_PATH }}"
    expose:
      - "8091"
    # No compose healthcheck: the published image is distroless (no shell/curl), so a
    # `curl /health` healthcheck can't run in-container. We rely on `depends_on` ordering
    # + Envoy fronting instead. A binary `--healthcheck` subcommand is the deferred fix.
