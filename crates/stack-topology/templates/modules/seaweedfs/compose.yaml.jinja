# SeaweedFS + one-shot bucket init
services:
  seaweedfs:
    image: chrislusf/seaweedfs:latest
    restart: unless-stopped
    command: mini -dir=/data
    expose:
      - "9333"
      - "8333"
    volumes:
      - {{ env.DATA_ROOT }}/seaweedfs:/data
    healthcheck:
      test:
        - "CMD-SHELL"
        - "wget -q --spider http://127.0.0.1:9333/ && echo ok || exit 1"
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 5s
{%- if objects %}
{%- set obj = connections.object_store.0 %}

  seaweedfs-init:
    image: amazon/aws-cli:latest
    restart: on-failure
    depends_on:
      seaweedfs:
        condition: service_healthy
    environment:
      AWS_ACCESS_KEY_ID: {{ obj.credential.access_key_id }}
      AWS_SECRET_ACCESS_KEY: {{ obj.credential.secret_access_key }}
      AWS_DEFAULT_REGION: {{ obj.credential.region }}
    entrypoint:
      - "sh"
      - "-c"
      - |
        echo "Waiting for SeaweedFS S3...";
        until aws --endpoint-url http://seaweedfs:8333 s3 ls >/dev/null 2>&1; do sleep 2; done;
{%- for name in objects %}
        aws --endpoint-url http://seaweedfs:8333 s3 mb s3://{{ name }} 2>&1 || true;
{%- endfor %}
        echo "Buckets ready.";
{%- endif %}
