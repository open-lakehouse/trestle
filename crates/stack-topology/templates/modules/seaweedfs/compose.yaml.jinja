# SeaweedFS + one-shot bucket init — contributed by the `seaweedfs` module.
#
# Rendered whole against the typed `RenderCtx`. As the object_store provider, SeaweedFS reads
# its own resolved connection (`connections.object_store.0`) for the S3 credential, and iterates
# the buckets it provisions (`objects`) to build the one-shot init — no compose-var credential
# fallbacks and no planner-spliced shell placeholder.
{%- set obj = connections.object_store.0 %}
services:
  seaweedfs:
    image: chrislusf/seaweedfs:latest
    restart: unless-stopped
    command: mini -dir=/data
    ports:
      - "9333:9333"
      - "9000:8333"
    volumes:
      # Durable object state under the stack's data root (default ./.data).
      - {{ env.DATA_ROOT }}/seaweedfs:/data
    healthcheck:
      test:
        - "CMD-SHELL"
        - "wget -q --spider http://127.0.0.1:9333/ && echo ok || exit 1"
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 5s
{%- if objects %}

  seaweedfs-init:
    image: amazon/aws-cli:latest
    restart: on-failure
    profiles: [svc, full]
    depends_on:
      seaweedfs:
        condition: service_healthy
    environment:
      AWS_ACCESS_KEY_ID: {{ obj.credential.access_key_id }}
      AWS_SECRET_ACCESS_KEY: {{ obj.credential.secret_access_key }}
      AWS_DEFAULT_REGION: {{ obj.credential.region }}
    entrypoint:
      - "sh"
      - "-c"
      - |
        echo "Waiting for SeaweedFS S3...";
        until aws --endpoint-url http://seaweedfs:8333 s3 ls >/dev/null 2>&1; do sleep 2; done;
{%- for name in objects %}
        aws --endpoint-url http://seaweedfs:8333 s3 mb s3://{{ name }} 2>&1 || true;
{%- endfor %}
        echo "Buckets ready.";
{%- endif %}
