# Marimo notebooks — contributed by the `notebooks` module.
services:
  notebooks:
    image: ghcr.io/marimo-team/marimo:latest-data-science
    restart: unless-stopped
    profiles: [svc, full, notebooks]
    command:
      - "marimo"
      - "edit"
      - "--no-token"
      - "--host"
      - "0.0.0.0"
      - "--port"
      - "8080"
      - "--base-url"
      - "/notebooks"
      - "--proxy"
      - "envoy:10000"
    environment:
      MLFLOW_TRACKING_URI: http://envoy:10000
      DATABRICKS_HOST: http://envoy:10000
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID:-seaweedfs}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY:-seaweedfs}
      AWS_REGION: ${AWS_DEFAULT_REGION:-us-east-1}
      MLFLOW_S3_ENDPOINT_URL: http://seaweedfs:8333
    volumes:
      - ./notebooks:/home/notebooks
    working_dir: /home/notebooks
    expose:
      - "8080"
