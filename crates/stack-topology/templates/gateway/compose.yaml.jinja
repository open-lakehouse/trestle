# Envoy gateway — contributed by the `envoy` module.
# `docker compose --profile svc up` brings up everything on the `svc` profile.
#
# This fragment is a `RenderSpec::Template`: the planner hands it `published_ports`, one
# `host:container` mapping per gateway listener — the shared listener plus a dedicated one for
# each gatewayed backend (e.g. an object store), plus the Envoy admin endpoint — so the host can
# reach every listener without this file hard-coding a port list.
services:
  envoy:
    image: envoyproxy/envoy:v1.34-latest
    restart: unless-stopped
    profiles: [svc, full]
    configs:
      - source: envoy_config
        target: /etc/envoy/envoy.yaml
    command: ["-c", "/etc/envoy/envoy.yaml", "--log-level", "warn"]
{%- if env.ENVOY_AUTH == "true" %}
    # Forward-auth on: the bootstrap's ext_authz filter calls Authelia, so wait for it to be
    # healthy before accepting traffic (the `authelia` module is pulled in by the ENVOY_AUTH knob).
    depends_on:
      authelia:
        condition: service_healthy
{%- endif %}
    ports:
{%- for p in published_ports %}
      - "{{ p.host }}:{{ p.container }}"
{%- endfor %}
