# Local environment overlay. Copy to `.env.local` and adjust as needed;
# `just up` and Docker Compose load `.env` first, then `.env.local` if present.
#
# The variables below mirror the env vars Databricks Apps injects into deployed
# apps, so app code reads the same names locally and on Databricks.
AWS_ACCESS_KEY_ID=seaweedfs
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=seaweedfs
ENVOY_PORT=9080
MLFLOW_EXPERIMENT_NAME=local-dev
MLFLOW_S3_ENDPOINT_URL=http://localhost:${SEAWEEDFS_S3_PORT:-9000}
MLFLOW_TRACKING_URI=http://localhost:${ENVOY_PORT:-9080}
PGWEB_PORT=8081
POSTGRES_DB=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_S3_PORT=9000
UC_DATABASE_URL=postgresql://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@db:5432/unitycatalog
UC_IMAGE=unitycatalog/unitycatalog:latest
