# Local environment overlay. Copy to `.env.local` and edit; `just up` and
# Docker Compose load `.env` first, then `.env.local`.
#
# Variable names match what Databricks Apps injects, so app code reads the
# same names locally and on Databricks.
{% for k, v in stack.env_vars | items -%}
{{ k }}={{ v }}
{% endfor %}
APP_LOG=info
