name: deploy

on:
  push:
    branches: [main]
  workflow_dispatch:
    inputs:
      target:
        description: "Databricks bundle target (dev / prod)"
        required: true
        default: dev
        type: choice
        options: [dev, prod]

permissions:
  contents: read
  id-token: write

concurrency:
  group: deploy-${{ '{{' }} github.event.inputs.target || 'dev' {{ '}}' }}
  cancel-in-progress: false

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    env:
      DATABRICKS_HOST: ${{ '{{' }} vars.DATABRICKS_HOST {{ '}}' }}
      # Resolved once here so the deploy steps reference `$TARGET` instead of
      # expanding `${{ '{{' }} ... {{ '}}' }}` inline in `run:` (template-injection).
      TARGET: ${{ '{{' }} github.event.inputs.target || 'dev' {{ '}}' }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          persist-credentials: false
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # master
        with:
          toolchain: stable
      - uses: Swatinem/rust-cache@e18b497796c12c097a38f9edb9d0641fb99eee32 # v2
      - uses: bufbuild/buf-setup-action@a47c93e0b1648d5651a065437926377d060baa99 # v1.50.0
{% if with_frontend %}
      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4
        with:
          node-version: "20"
          cache: npm
          cache-dependency-path: frontend/package-lock.json
      - name: build frontend
        run: |
          cd frontend
          npm ci
          npm run build
{%- endif %}

      - name: build server binary
        run: cargo build --release --bin {{ project_name | kebab_case }}-server

      - name: install databricks cli
        run: |
          curl -fsSL https://raw.githubusercontent.com/databricks/setup-cli/main/install.sh | sh

      - name: authenticate to Databricks (OIDC / workload identity)
        env:
          DATABRICKS_CLIENT_ID: ${{ '{{' }} vars.DATABRICKS_CLIENT_ID {{ '}}' }}
        run: |
          databricks auth env-vars > /dev/null

      - name: bundle validate
        run: databricks bundle validate -t "$TARGET"

      - name: bundle deploy
        run: databricks bundle deploy -t "$TARGET"

      - name: bundle run
        run: databricks bundle run -t "$TARGET" {{ project_name | snake_case }}

      - name: smoke test /healthz
        run: |
          set -e
          APP_URL=$(databricks apps get {{ project_name | kebab_case }} -o json | jq -r .url)
          for i in 1 2 3 4 5; do
            if curl -fsS "$APP_URL/healthz" >/dev/null; then
              echo "healthz OK"; exit 0
            fi
            sleep 5
          done
          echo "::error::healthz never became ready"
          exit 1
