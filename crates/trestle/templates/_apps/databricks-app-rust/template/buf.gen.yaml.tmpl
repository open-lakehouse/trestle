version: v2
inputs:
  - directory: proto
plugins:
{%- if runtime == 'buffa' %}
  - remote: buf.build/anthropics/buffa:v0.7.0
    out: crates/common/src/models/_gen
    opt:
      - json=true
      - file_per_package=true
{%- else %}
  - remote: buf.build/community/neoeinstein-prost:v0.4.0
    out: crates/common/src/models/_gen
    opt:
      - bytes=.
      - file_descriptor_set
      - compile_well_known_types
  - remote: buf.build/community/neoeinstein-prost-serde:v0.3.1
    out: crates/common/src/models/_gen
{%- endif %}
{%- if with_connect %}
  # ConnectRPC server facade. Generated by the locally-installed
  # `protoc-gen-connect-rust` plugin (cargo install); it emits service traits +
  # routers only, referencing the buffa models above via the absolute
  # `buffa_module` path (the `__buffa::view` types they already carry).
  # `protoc-gen-buffa-packaging` then stitches the per-service `mod.rs` tree.
  - local: protoc-gen-connect-rust
    out: crates/server/src/connect_gen
    opt:
      - buffa_module=::{{ project_name | snake_case }}_common::models
  - local: protoc-gen-buffa-packaging
    out: crates/server/src/connect_gen
    strategy: all
    opt:
      - filter=services
{%- endif %}
