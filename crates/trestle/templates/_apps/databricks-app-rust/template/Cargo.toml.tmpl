[workspace]
resolver = "2"
members = [
  "crates/common",
  "crates/server",
  "crates/client",
]

[workspace.package]
version = "0.1.0"
edition = "{{ rust_edition }}"
rust-version = "1.85"
{% if license != 'none' -%}
license = "{{ license }}"
{%- endif %}
authors = ["{{ gh_owner }}"]
repository = "https://github.com/{{ gh_owner }}/{{ project_name | kebab_case }}"

[workspace.dependencies]
axum = "0.8"
tokio = { version = "1", features = ["full"] }
tower = "0.5"
tower-http = { version = "0.6", features = ["cors", "trace", "fs"] }
http = "1"
reqwest = { version = "0.12", default-features = false, features = ["rustls-tls", "json"] }
url = "2"
futures = "0.3"
olai-http = "0.0.1"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "2"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
uuid = { version = "1", features = ["v4", "serde"] }
chrono = { version = "0.4", features = ["serde"] }
{%- if runtime == 'buffa' %}
buffa = "0.7"
buffa-types = "0.7"
{%- else %}
prost = "0.14"
prost-types = "0.14"
{%- endif %}
async-trait = "0.1"
{%- if with_connect %}
# ConnectRPC server runtime + the http-body trait its generated client refers to.
connectrpc = { version = "0.7", features = ["server", "axum"] }
http-body = "1"
{%- endif %}
