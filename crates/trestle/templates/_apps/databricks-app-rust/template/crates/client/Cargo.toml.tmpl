[package]
name = "{{ project_name | kebab_case }}-client"
version.workspace = true
edition.workspace = true
{% if license != 'none' -%}
license.workspace = true
{%- endif %}

[lib]
doctest = false
{%- if with_frontend %}
# `cdylib` so the client can be built to a browser module with `wasm-pack`
# (`just build-wasm`); `rlib` keeps it usable as a normal Rust dependency.
crate-type = ["rlib", "cdylib"]
{%- endif %}

[dependencies]
{{ project_name | kebab_case }}-common = { path = "../common" }
reqwest = { workspace = true }
url = { workspace = true }
futures = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
thiserror = { workspace = true }
{%- if runtime == 'buffa' %}
buffa = { workspace = true, features = ["json"] }
buffa-types = { workspace = true }
{%- else %}
prost = { workspace = true }
prost-types = { workspace = true }
{%- endif %}
chrono = { workspace = true }
uuid = { workspace = true }
{%- if with_frontend %}

# Transport is selected by target: the native cloud client off-wasm, the
# browser (fetch) client on wasm32. The generated client picks between them with
# `cfg(target_arch = "wasm32")`, so the one crate builds both ways.
[target.'cfg(not(target_arch = "wasm32"))'.dependencies]
olai-http = { workspace = true }

[target.'cfg(target_arch = "wasm32")'.dependencies]
olai-http-wasm = { workspace = true }
wasm-bindgen = { workspace = true }
wasm-bindgen-futures = { workspace = true }
serde-wasm-bindgen = { workspace = true }
# `uuid` needs a browser randomness source on wasm32 (it errors at compile time
# otherwise); the `js` feature wires it to the Web Crypto API.
uuid = { workspace = true, features = ["js"] }
{%- else %}
olai-http = { workspace = true }
{%- endif %}
