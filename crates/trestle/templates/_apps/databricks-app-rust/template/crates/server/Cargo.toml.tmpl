[package]
name = "{{ project_name | kebab_case }}-server"
version.workspace = true
edition.workspace = true
{% if license != 'none' -%}
license.workspace = true
{%- endif %}

[[bin]]
name = "{{ project_name | kebab_case }}-server"
path = "src/main.rs"

[features]
# The generated route fns (`gen/<service>/server.rs`) and the request extractors
# in the common crate are gated behind an `axum` feature. Making `axum` an
# optional dep auto-creates the matching feature; enabling it also turns on the
# common crate's `axum` feature so its extractors compile. On by default so the
# binary builds out of the box.
default = ["axum"]
axum = ["dep:axum", "{{ project_name | kebab_case }}-common/axum"]

[dependencies]
{{ project_name | kebab_case }}-common = { path = "../common" }
axum = { workspace = true, optional = true }
tokio = { workspace = true }
tower = { workspace = true }
tower-http = { workspace = true }
http = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
thiserror = { workspace = true }
tracing = { workspace = true }
tracing-subscriber = { workspace = true }
async-trait = { workspace = true }
{%- if runtime == 'buffa' %}
buffa = { workspace = true, features = ["json"] }
buffa-types = { workspace = true }
{%- else %}
prost = { workspace = true }
prost-types = { workspace = true }
{%- endif %}
chrono = { workspace = true }
uuid = { workspace = true }
{%- if with_connect %}
connectrpc = { workspace = true }
http-body = { workspace = true }
{%- endif %}
