# Trestle code-generation config for {{ project_name }}.
#
# `trestle generate -c trestle.yaml` reads this file, builds the proto descriptor
# (run `just regen` first to refresh `api.bin`), and writes Rust + TypeScript
# code into the four output directories below.

descriptors: api.bin
buf_gen: buf.gen.yaml

generate:
  # Protobuf runtime the generated code consumes: "prost" (default) or "buffa".
  runtime: {{ runtime }}
  output_common: crates/common/src/models/_gen
  output_models: crates/common/src/models
  models_subdir: _gen
  output_server: crates/server/src/gen
  output_client: crates/client/src/gen
  context_type: crate::api::RequestContext
  result_type: crate::api::Result
  models_crate_name: "{{ project_name | snake_case }}_common"
  models_path_template: "{{ project_name | snake_case }}_common::models::{service}::v1"
  models_path_crate_template: "crate::models::{service}::v1"
  python_typings_filename: client.pyi
{% if with_frontend %}
  typescript:
    output: frontend/src/api
    aggregate_client_name: "{{ project_name | pascal_case }}Client"
    client_crate_name: "{{ project_name | kebab_case }}-client"
    error_base_class: "ApiError"
    error_code_prefix: "{{ project_name | screaming_snake_case }}_"
{%- endif %}
